---
import { Icon } from "astro-icon/components";
import { toolkit } from "../../data/about";
---

<div class="pt-8 border-t border-white/10">
  <h2 class="text-2xl font-bold text-white mb-8">My Toolkit</h2>
  <div class="flex flex-wrap gap-3">
    {
      toolkit.map((tech) => (
        <span class="flex items-center gap-2 px-5 py-2.5 rounded-xl bg-neutral-900/40 backdrop-blur-md border border-white/10 text-sm font-medium text-neutral-300 hover:bg-neutral-800 hover:text-white hover:border-amber-400/50 hover:shadow-lg hover:shadow-amber-400/10 hover:-translate-y-0.5 transition-all duration-300 cursor-default group">
          <Icon
            name={tech.icon}
            class="w-4 h-4 text-neutral-500 group-hover:text-amber-400 transition-colors"
          />
          {tech.name}
        </span>
      ))
    }
  </div>
</div>
