---
import { Icon } from "astro-icon/components";
import { highlights } from "../../data/about";
---

<div>
  <h3 class="text-2xl font-bold text-white mb-8">Highlights</h3>
  <div class="space-y-4">
    {
      highlights.map((item) => (
        <div class="p-5 rounded-2xl bg-neutral-900/30 backdrop-blur-sm border border-white/10 hover:border-amber-400/40 hover:-translate-y-1 transition-all duration-300 flex gap-5 items-center shadow-lg">
          <Icon name={item.icon} class="w-8 h-8 text-amber-400 shrink-0" />
          <div>
            <h4 class="text-white font-bold leading-snug">{item.title}</h4>
            <p class="text-sm text-neutral-400 mt-1">{item.desc}</p>
          </div>
        </div>
      ))
    }
  </div>
</div>
