import { Icon } from "astro-icon/components";
import { projects } from "../../data/projects";

import ProjectCard from "./Card.astro";
---

<section
  id="work"
  class="scroll-mt-0 min-h-svh flex flex-col justify-center max-w-6xl mx-auto px-6 py-24"
>
  <div
    class="flex flex-col lg:flex-row lg:items-end justify-between mb-16 gap-8"
  >
    <div class="max-w-2xl">
      <div
        class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-xs font-medium text-amber-400 mb-6 uppercase tracking-widest"
      >
        <Icon name="lucide:code" class="w-4 h-4" /> Open Source
      </div>
      <h2
        class="text-4xl md:text-6xl font-extrabold text-white tracking-tight mb-4"
      >
        Featured Picks.
      </h2>
      <p class="text-neutral-400 text-lg md:text-xl leading-relaxed">
        My top open-source tools, integrations, and projects I actively
        maintain.
      </p>
    </div>

    <div class="flex flex-wrap items-center gap-3 shrink-0">
      <a
        href="https://modrinth.com/user/xhyrom"
        target="_blank"
        class="px-6 py-3 rounded-full bg-neutral-900 border border-white/10 text-white text-sm font-semibold hover:bg-neutral-800 hover:border-amber-400/50 hover:-translate-y-1 transition-all duration-300 flex items-center gap-2 shadow-lg"
      >
        <Icon name="lucide:package" class="w-4 h-4 text-green-400" /> Modrinth
      </a>
      <a
        href="https://github.com/xhyrom"
        target="_blank"
        class="px-6 py-3 rounded-full bg-neutral-900 border border-white/10 text-white text-sm font-semibold hover:bg-neutral-800 hover:border-amber-400/50 hover:-translate-y-1 transition-all duration-300 flex items-center gap-2 shadow-lg"
      >
        <Icon name="lucide:github" class="w-4 h-4" /> GitHub
      </a>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {projects.map((project) => <ProjectCard {...project} />)}
  </div>
</section>
