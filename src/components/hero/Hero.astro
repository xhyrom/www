import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";

import me from "../../assets/me.png";
---

<section
  id="home"
  class="min-h-svh flex flex-col items-center justify-center text-center animate-fade-in-up pb-20 pt-20"
>
  <div class="relative mb-8 group">
    <div
      class="absolute -inset-2 bg-amber-400 rounded-full blur-lg opacity-30 group-hover:opacity-60 transition duration-500"
    >
    </div>

    <Image
      src={me}
      alt="Jozef"
      class="relative w-28 h-28 md:w-32 md:h-32 rounded-full object-cover ring-1 ring-white/20 shadow-2xl"
      width={128}
      height={128}
    />
  </div>

  <h1
    class="text-5xl md:text-7xl font-extrabold tracking-tight mb-6 text-white"
  >
    Hi, <span class="text-amber-400 drop-shadow-[0_0_15px_rgba(251,191,36,0.6)]"
      >Jozef</span
    > here.
  </h1>

  <p
    class="text-lg md:text-xl text-neutral-400 max-w-2xl mb-10 leading-relaxed px-4"
  >
    I'm a 17-year-old developer who's been fascinated with building things since
    I was ten. I love coming up with creative, efficient, and useful solutions
    to problems.
  </p>

  <div class="flex flex-wrap justify-center items-center gap-4">
    <a
      href="mailto:jozef@steinhubl.com"
      class="px-8 py-3 rounded-full bg-white text-black font-bold hover:scale-105 transition-transform duration-300 flex items-center gap-2"
    >
      <Icon name="lucide:mail" class="w-5 h-5" />
      Contact Me
    </a>

    <a
      href="#work"
      class="px-8 py-3 rounded-full bg-white/5 border border-white/10 text-white font-semibold hover:bg-white/10 transition-colors duration-300 backdrop-blur-sm"
    >
      View My Work
    </a>
  </div>
</section>
